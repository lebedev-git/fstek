# Шаблон окружения для HTTP-сервера MCP. Скопируй в .env и подставь свой токен.
# Реальный .env в git НЕ коммитится (см. .gitignore).

# Bearer-токен для сетевого доступа к MCP. Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MCP_TOKEN=change-me-to-a-strong-random-token

# Порт HTTP-сервера MCP (npm run mcp:http)
MCP_HTTP_PORT=1338

# Хост прослушивания. 0.0.0.0 — доступ по сети; 127.0.0.1 — только локально.
MCP_HTTP_HOST=0.0.0.0
